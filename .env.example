# ============================================================
# POLYKIENGS - Environment Configuration
# ============================================================

# --- API Endpoints ---
POLYMARKET_API_URL=https://clob.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Wallet (REQUIRED) ---
# Your private key for signing trades (keep this SECRET!)
PRIVATE_KEY=your_private_key_here
# Your Polymarket proxy wallet address (Alamat Signer)
PROXY_WALLET=your_proxy_wallet_address

# ============================================================
# MODE AMAN - MINGGU PERTAMA (Rekomendasi)
# Setelah 1 minggu lancar, ubah ke Mode Normal di bawah
# ============================================================

# --- Scanning (Mode Aman) ---
MAX_WALLETS=5000
SCAN_BATCH_SIZE=50
SCAN_INTERVAL=60

# --- Trading (Mode Aman) ---
INITIAL_BANKROLL=15
MAX_BET_FRACTION=0.25
MIN_EDGE=0.07
MIN_CONFIDENCE=0.75
MAX_CONCURRENT_BETS=3

# --- Trader Selection ---
MIN_WIN_RATE=0.60
MIN_TRADES=20
TOP_TRADERS_COUNT=7

# --- Learning ---
LEARNING_RATE=0.01
DECAY_FACTOR=0.995

# ============================================================
# MODE NORMAL - Setelah 1 minggu aman, ubah ke ini:
# ============================================================
# MAX_WALLETS=14000
# SCAN_BATCH_SIZE=100
# SCAN_INTERVAL=30
# MIN_EDGE=0.05
# MIN_CONFIDENCE=0.70
# MAX_CONCURRENT_BETS=5

# ============================================================
# MODE AGRESIF - Setelah 1 bulan profit konsisten:
# ============================================================
# MAX_WALLETS=14000
# SCAN_BATCH_SIZE=100
# SCAN_INTERVAL=20
# MIN_EDGE=0.04
# MIN_CONFIDENCE=0.65
# MAX_CONCURRENT_BETS=7
# MAX_BET_FRACTION=0.30
