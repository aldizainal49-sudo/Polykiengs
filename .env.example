# ============================================================
# POLYKIENGS - Environment Configuration
# ============================================================

# --- API Endpoints ---
POLYMARKET_API_URL=https://clob.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Wallet (REQUIRED) ---
PRIVATE_KEY=your_private_key_here
PROXY_WALLET=your_proxy_wallet_address

# --- API Credentials (REQUIRED) ---
# Generate using py-clob-client:
#   pip install py-clob-client
#   python3 -c "
#   from py_clob_client.client import ClobClient
#   client = ClobClient('https://clob.polymarket.com', key='0xYOUR_PRIVATE_KEY', chain_id=137)
#   creds = client.derive_api_key()
#   print(creds)
#   "
# Copy the output values here:
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ============================================================
# MODE AMAN - MINGGU PERTAMA (Rekomendasi)
# ============================================================
MAX_WALLETS=5000
SCAN_BATCH_SIZE=50
SCAN_INTERVAL=60
INITIAL_BANKROLL=15
MAX_BET_FRACTION=0.25
MIN_EDGE=0.07
MIN_CONFIDENCE=0.75
MAX_CONCURRENT_BETS=3
MIN_WIN_RATE=0.60
MIN_TRADES=20
TOP_TRADERS_COUNT=7
LEARNING_RATE=0.01
DECAY_FACTOR=0.995

# ============================================================
# MODE NORMAL - Setelah 1 minggu aman, ubah ke ini:
# ============================================================
# MAX_WALLETS=14000
# SCAN_BATCH_SIZE=100
# SCAN_INTERVAL=30
# MIN_EDGE=0.05
# MIN_CONFIDENCE=0.70
# MAX_CONCURRENT_BETS=5

# ============================================================
# MODE AGRESIF - Setelah 1 bulan profit konsisten:
# ============================================================
# MAX_WALLETS=14000
# SCAN_BATCH_SIZE=100
# SCAN_INTERVAL=20
# MIN_EDGE=0.04
# MIN_CONFIDENCE=0.65
# MAX_CONCURRENT_BETS=7
# MAX_BET_FRACTION=0.30
