# ============================================================
# POLYKIENGS - Environment Configuration
# ============================================================

# --- API Endpoints ---
POLYMARKET_API_URL=https://clob.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Wallet (REQUIRED) ---
# Your private key for signing trades (keep this SECRET!)
PRIVATE_KEY=your_private_key_here
# Your Polymarket proxy wallet address
PROXY_WALLET=your_proxy_wallet_address

# --- Scanning ---
# Number of wallets to scan (default: 14000)
MAX_WALLETS=14000
# Batch size for parallel requests
SCAN_BATCH_SIZE=100
# Minutes between full scans
SCAN_INTERVAL=30

# --- Trading ---
# Starting capital in USD
INITIAL_BANKROLL=15
# Maximum fraction of bankroll per bet (0.25 = quarter Kelly)
MAX_BET_FRACTION=0.25
# Minimum edge required to place a bet (0.05 = 5%)
MIN_EDGE=0.05
# Minimum confidence to execute (0-1)
MIN_CONFIDENCE=0.7
# Maximum simultaneous bets
MAX_CONCURRENT_BETS=5

# --- Trader Selection ---
# Minimum win rate for candidate traders (0.60 = 60%)
MIN_WIN_RATE=0.60
# Minimum number of trades to consider a trader
MIN_TRADES=20
# Number of top traders to follow
TOP_TRADERS_COUNT=7

# --- Learning ---
# How fast the bot adjusts its Kelly multiplier
LEARNING_RATE=0.01
# How much to reduce Kelly after a loss
DECAY_FACTOR=0.995
